# Copy to `.env` and adjust. Vite only reads vars prefixed with VITE_.
#
# If unset, the app uses:
#   - http://127.0.0.1:8000 when you open the UI on localhost
#   - http://<same-host-as-the-page>:8000 otherwise (good on a Raspberry Pi
#     when the browser hostname matches where uvicorn runs)
#
# Examples:
# VITE_API_URL=http://127.0.0.1:8000
# VITE_API_URL=http://10.0.0.111:8000
# VITE_API_URL=http://raspberrypi.local:8000

# VITE_API_URL=
